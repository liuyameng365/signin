# Flask 基础配置
# 生产环境请务必替换为随机高强度字符串
SECRET_KEY=change-me-in-production

# 数据库配置（二选一）
# 1) 推荐：直接使用 DATABASE_URL（优先级最高）
# DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/signin?charset=utf8mb4

# 2) 或者使用下方拆分字段（app.py 会自动拼接）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=signin
MYSQL_CHARSET=utf8mb4

# 开发调试用：切回 SQLite（1=开启，0=关闭）
# 默认是 0（使用 MySQL）
USE_SQLITE=0
