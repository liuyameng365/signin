# Flask 基础配置
# 生产环境请务必替换为随机高强度字符串
SECRET_KEY=change-me-in-production

# 数据库配置（PostgreSQL）
# 1) 推荐：直接使用 DATABASE_URL（优先级最高）
# DATABASE_URL=postgresql+psycopg2://postgres:password@127.0.0.1:5432/signin

# 2) 或者使用下方拆分字段（app.py 会自动拼接）
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=signin

# 后台默认管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_DISPLAY_NAME=系统管理员
ADMIN_ROLE=manager
